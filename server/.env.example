# ── Database ──
# PostgreSQL connection string (required)
# For Supabase pooler (recommended for Prisma):
#   Go to Project Settings → Database → Connection string → Session pooler
#   Format: postgresql://postgres.[REF]:[PASSWORD]@aws-REGION.pooler.supabase.com:5432/postgres
#   Requires relationMode = "prisma" in schema.prisma
# For Supabase direct connection:
#   Format: postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres?sslmode=require
DATABASE_URL="postgresql://postgres.REF:PASSWORD@aws-REGION.pooler.supabase.com:5432/postgres"

# ── Supabase (Auth + Storage) ──
# Get from Supabase Project Settings → API
SUPABASE_URL="https://YOUR_REF.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ── Server ──
PORT=5000

# ── Email (SMTP) ──
# Used for sending emails (password reset, notifications, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Alternative email provider (optional)
RESEND_API_KEY=
EMAIL_FROM="Your School Name <your-email@gmail.com>"

# ── CORS ──
# Comma-separated list of allowed origins (no spaces)
CORS_ORIGINS="http://localhost:5173,http://localhost:3000"

# ── Setup Token ──
# Required for creating the first admin user (POST /api/setup/init).
# Generate a random UUID or long string for production.
# SETUP_TOKEN="change-this-to-a-random-secret-string"
