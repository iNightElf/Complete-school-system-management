# ── Database ──
# PostgreSQL connection string (required)
# For Supabase pooler (recommended for Prisma):
#   Go to Project Settings → Database → Connection string → Session pooler
#   Format: postgresql://postgres.[REF]:[PASSWORD]@aws-REGION.pooler.supabase.com:5432/postgres
#   Requires relationMode = "prisma" in schema.prisma
# For Supabase direct connection:
#   Format: postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres?sslmode=require
DATABASE_URL="postgresql://postgres.REF:PASSWORD@aws-REGION.pooler.supabase.com:5432/postgres"

# ── Supabase (Auth + Storage) ──
# Get from Supabase Project Settings → API
SUPABASE_URL="https://YOUR_REF.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
# Anon/public key — used by the client for browser-side Supabase Auth
SUPABASE_ANON_KEY="your-anon-key"

# These are also needed by the client at build time (passed as Docker build args).
# See client/.env.example for the browser-side (anon key) equivalents.
# VITE_SUPABASE_URL — same as SUPABASE_URL above
# VITE_SUPABASE_ANON_KEY — get from Supabase Project Settings → API → anon/public

# ── Server ──
PORT=7860
NODE_ENV=production
# Public URL of the app (used for email verification redirect links)
# Format for Hugging Face Spaces: https://YOUR_USERNAME-YOUR_SPACE.hf.space
APP_URL="https://YOUR_USERNAME-YOUR_SPACE.hf.space"

# ── Email (SMTP) ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM="Your School Name <your-email@gmail.com>"

# ── CORS ──
# Comma-separated list of allowed origins (no spaces).
# Must include your HF Space URL in production.
CORS_ORIGINS="https://YOUR_USERNAME-YOUR_SPACE.hf.space"

# ── Setup Token ──
# MANDATORY in production. Protects POST /api/setup/init from unauthorized registration.
# Generate a random string (e.g., `openssl rand -hex 32`).
# The server will refuse all setup requests if this is missing in production.
SETUP_TOKEN="replace-with-a-random-secret"
