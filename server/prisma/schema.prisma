generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model user {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  emailVerified Boolean  @default(false)
  image         String?
  role          String    @default("viewer") // "admin" | "viewer"
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  session       session[]
  account       account[]
}

model session {
  id           String    @id @default(uuid())
  expiresAt    DateTime
  token        String    @unique
  ipAddress    String?
  userAgent    String?
  userId       String
  user         user      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model account {
  id                    String    @id @default(uuid())
  accountId             String
  providerId            String
  userId                String
  user                  user      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([accountId, providerId])
}

model verification {
  id         String    @id @default(uuid())
  identifier String
  expiresAt  DateTime
  token      String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([identifier, token])
}

model Student {
  id          String           @id @default(uuid())
  class       String
  classId     String?          @map("class_id")
  classRel    SchoolClass?     @relation(fields: [classId], references: [id])
  roll        String?
  name        String
  fatherName  String?
  motherName  String?
  contact     String?
  photo       Bytes?
  createdAt   DateTime         @default(now())
  results     Result[]
  transactions Transaction[]
  feeAssignments FeeAssignment[]
  paymentAllocations PaymentAllocation[]

  @@index([class])
  @@index([classId])
}

model Teacher {
  id          String   @id @default(uuid())
  designation String
  name        String
  email       String?
  contact     String?
  photo       Bytes?
  createdAt   DateTime @default(now())
}

model Staff {
  id          String   @id @default(uuid())
  role        String
  name        String
  email       String?
  contact     String?
  photo       Bytes?
  createdAt   DateTime @default(now())
}

model SchoolClass {
  id        String    @id @default(uuid())
  name      String    @unique
  order     Int       @default(0)
  subjects  Subject[]
  books     Book[]
  students  Student[]
  feeSchedules FeeSchedule[]
}

model Subject {
  id          String      @id @default(cuid())
  name        String
  fullMarks   Int
  order       Int         @default(0)
  classId     String
  class       SchoolClass @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@unique([name, classId])
  @@index([classId])
}

model Book {
  id          String      @id @default(uuid())
  name        String
  publication String?
  mrp         Decimal     @db.Decimal(12, 2)
  discounted  Decimal     @db.Decimal(12, 2)
  sell        Decimal     @db.Decimal(12, 2)
  classId     String
  class       SchoolClass @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@index([classId])
}

model AcademicYear {
  id        String   @id @default(uuid())
  name      String   @unique
  startDate DateTime @map("start_date")
  endDate   DateTime @map("end_date")
  isActive  Boolean  @default(false) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  feeSchedules FeeSchedule[]

  @@map("academic_years")
}

model FeeSchedule {
  id             String        @id @default(uuid()) @db.Uuid
  academicYearId String        @map("academic_year_id")
  academicYear   AcademicYear  @relation(fields: [academicYearId], references: [id])
  classId        String?       @map("class_id")
  classRel       SchoolClass?  @relation(fields: [classId], references: [id])
  category       String        @db.VarChar(100)
  amount         Decimal       @db.Decimal(12, 2)
  frequency      String        @default("MONTHLY") @db.VarChar(20)
  createdAt      DateTime      @default(now()) @map("created_at")

  paymentAllocations PaymentAllocation[]

  @@index([academicYearId, classId, category])
  @@map("fee_schedules")
}

model PaymentAllocation {
  id            String      @id @default(uuid())
  transactionId String      @map("transaction_id") @db.Uuid
  transaction   Transaction @relation(fields: [transactionId], references: [id])
  feeScheduleId String?     @map("fee_schedule_id") @db.Uuid
  feeSchedule   FeeSchedule? @relation(fields: [feeScheduleId], references: [id])
  studentId     String      @map("student_id")
  student       Student     @relation(fields: [studentId], references: [id])
  period        String?     @db.VarChar(20)
  amount        Decimal     @db.Decimal(12, 2)
  createdAt     DateTime    @default(now()) @map("created_at")

  @@index([transactionId])
  @@index([feeScheduleId])
  @@index([studentId, period])
  @@map("payment_allocations")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id") @db.VarChar(100)
  action     String   @db.VarChar(50)
  entityType String   @map("entity_type") @db.VarChar(50)
  entityId   String?  @map("entity_id") @db.VarChar(100)
  details    String?  @db.Text
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

model Category {
  id   String @id @default(uuid())
  type String @db.VarChar(20)
  name String @db.VarChar(100)

  @@unique([type, name])
  @@map("categories")
}

model Result {
  id          String   @id @default(uuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  term        String
  marks       Json
  attendance  Json?
  comment     String?
  createdAt   DateTime @default(now())

  @@unique([studentId, term])
  @@index([studentId])
}

model Transaction {
  id                    String    @id @default(uuid()) @db.Uuid
  transactionDate       DateTime  @map("transaction_date")
  transactionType       String    @map("transaction_type") @db.VarChar(50)
  sourceAccount         String?   @map("source_account") @db.VarChar(100)
  destinationAccount    String?   @map("destination_account") @db.VarChar(100)
  amount                Decimal   @db.Decimal(12, 2)
  category              String?   @db.VarChar(100)
  description           String?   @db.Text
  studentId             String?   @map("student_id")
  student               Student?  @relation(fields: [studentId], references: [id], onDelete: SetNull)
  className             String?   @map("class_name") @db.VarChar(100)
  affectsIncomeLedger   Boolean   @default(false) @map("affects_income_ledger")
  affectsExpenseLedger  Boolean   @default(false) @map("affects_expense_ledger")
  createdBy             String?   @map("created_by") @db.VarChar(100)
  approvedBy            String?   @map("approved_by") @db.VarChar(100)
  referenceId           String?   @map("reference_id") @db.VarChar(255)
  feeMonth              String?   @map("fee_month") @db.VarChar(20)
  isCancelled           Boolean   @default(false) @map("is_cancelled")
  cancelledAt           DateTime? @map("cancelled_at")
  cancelledBy           String?   @map("cancelled_by") @db.VarChar(100)
  cancelReason          String?   @map("cancel_reason") @db.Text
  reversalOfId          String?   @map("reversal_of_id") @db.Uuid
  createdAt             DateTime  @default(now()) @map("created_at")

  paymentAllocations PaymentAllocation[]

  @@index([transactionDate])
  @@index([transactionType])
  @@index([studentId])
  @@index([className])
  @@index([category])
  @@index([studentId, category])
  @@index([className, category])
  @@index([transactionType, affectsIncomeLedger])
  @@index([reversalOfId])
  @@map("transactions")
}

model FeeAssignment {
  id          String   @id @default(uuid())
  studentId   String   @map("student_id")
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  feeType     String   @map("fee_type") @db.VarChar(50)
  amount      Decimal  @db.Decimal(12, 2) @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([studentId, feeType])
  @@index([active, studentId])
  @@map("fee_assignments")
}

model OpeningBalance {
  id        String   @id @default(uuid())
  fiscalYear String  @map("fiscal_year") @db.VarChar(10)
  account   String   @db.VarChar(100)
  amount    Decimal  @db.Decimal(12, 2) @default(0)
  updatedAt DateTime @updatedAt @map("updated_at")
  updatedBy String?  @map("updated_by") @db.VarChar(100)

  @@unique([fiscalYear, account])
  @@map("opening_balances")
}

model OpeningBalanceHistory {
  id         String   @id @default(uuid())
  fiscalYear String   @map("fiscal_year") @db.VarChar(10)
  account    String   @db.VarChar(100)
  oldAmount  Decimal  @db.Decimal(12, 2) @default(0) @map("old_amount")
  newAmount  Decimal  @db.Decimal(12, 2) @default(0) @map("new_amount")
  changedBy  String?  @map("changed_by") @db.VarChar(100)
  changedAt  DateTime @default(now()) @map("changed_at")

  @@index([fiscalYear, account])
  @@map("opening_balance_history")
}
