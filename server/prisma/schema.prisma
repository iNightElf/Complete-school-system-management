generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "postgresql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

model user {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  role          String    @default("viewer") // "admin" | "accountant" | "teacher" | "viewer"
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([role])
}

model Student {
  id          String           @id @default(uuid())
  class       String
  classId     String?          @map("class_id")
  classRel    SchoolClass?     @relation(fields: [classId], references: [id], onDelete: SetNull)
  studentId   String           @unique @map("student_id")
  roll        String?
  session     String?
  name        String
  fatherName  String?
  motherName  String?
  contact     String?
  photo       Bytes?
  photoPath   String?          @map("photo_path")
  deletedAt   DateTime?
  graduatedAt DateTime?
  createdAt   DateTime         @default(now())
  results     Result[]
  transactions Transaction[]
  feeWaivers  FeeWaiver[]
  studentAssignments StudentFeeAssignment[]
  paymentAllocations PaymentAllocation[]

  @@index([class])
  @@index([classId])
  @@index([session])
}

model Teacher {
  id          String   @id @default(uuid())
  designation String
  name        String
  email       String?
  contact     String?
  photo       Bytes?
  photoPath   String?  @map("photo_path")
  deletedAt   DateTime?
  createdAt   DateTime @default(now())

  @@index([name])
  @@index([designation])
}

model Staff {
  id          String   @id @default(uuid())
  role        String
  name        String
  email       String?
  contact     String?
  photo       Bytes?
  photoPath   String?  @map("photo_path")
  deletedAt   DateTime?
  createdAt   DateTime @default(now())

  @@index([name])
  @@index([role])
}

model SchoolClass {
  id        String    @id @default(uuid())
  name      String    @unique
  order     Int       @default(0)
  subjects  Subject[]
  books     Book[]
  students  Student[]
  feeSchedules FeeSchedule[]
}

model Subject {
  id          String      @id @default(cuid())
  name        String
  fullMarks   Int
  order       Int         @default(0)
  classId     String
  class       SchoolClass @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@unique([name, classId])
  @@index([classId])
}

model Book {
  id          String      @id @default(uuid())
  name        String
  publication String?
  mrp         Decimal     @db.Decimal(12, 2)
  discounted  Decimal     @db.Decimal(12, 2)
  sell        Decimal     @db.Decimal(12, 2)
  classId     String
  class       SchoolClass @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@index([classId])
}

model AcademicYear {
  id        String   @id @default(uuid())
  name      String   @unique
  startDate DateTime @map("start_date")
  endDate   DateTime @map("end_date")
  isActive  Boolean  @default(false) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  feeSchedules FeeSchedule[]

  @@map("academic_years")
}

model FeeSchedule {
  id             String        @id @default(uuid()) @db.Uuid
  academicYearId String        @map("academic_year_id")
  academicYear   AcademicYear  @relation(fields: [academicYearId], references: [id])
  classId        String?       @map("class_id")
  classRel       SchoolClass?  @relation(fields: [classId], references: [id])
  category       String        @db.VarChar(100)
  amount         Decimal       @db.Decimal(12, 2)
  frequency      String        @default("MONTHLY") @db.VarChar(20)
  applicability  String        @default("AUTO") @db.VarChar(20) // AUTO or ASSIGNED_ONLY
  effectiveFrom  DateTime?     @map("effective_from")
  effectiveTo    DateTime?     @map("effective_to")
  createdAt      DateTime      @default(now()) @map("created_at")

  paymentAllocations PaymentAllocation[]
  waivers FeeWaiver[]
  studentAssignments StudentFeeAssignment[]

  @@unique([academicYearId, classId, category, frequency])
  @@index([academicYearId, classId, category])
  @@map("fee_schedules")
}

model PaymentAllocation {
  id            String      @id @default(uuid())
  transactionId String      @map("transaction_id") @db.Uuid
  transaction   Transaction @relation(fields: [transactionId], references: [id])
  feeScheduleId String?     @map("fee_schedule_id") @db.Uuid
  feeSchedule   FeeSchedule? @relation(fields: [feeScheduleId], references: [id])
  studentId     String      @map("student_id")
  student       Student     @relation(fields: [studentId], references: [id])
  period        String?     @db.VarChar(20)
  amount        Decimal     @db.Decimal(12, 2)
  createdAt     DateTime    @default(now()) @map("created_at")

  @@index([transactionId])
  @@index([feeScheduleId])
  @@index([studentId, period])
  @@map("payment_allocations")
}

model SchoolSetting {
  id    String @id @default(uuid())
  key   String @unique
  value String @db.Text

  @@map("school_settings")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id") @db.VarChar(100)
  action     String   @db.VarChar(50)
  entityType String   @map("entity_type") @db.VarChar(50)
  entityId   String?  @map("entity_id") @db.VarChar(100)
  details    String?  @db.Text
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@index([entityType, entityId])
  @@index([action])
  @@index([userId])
  @@map("audit_logs")
}

model Category {
  id   String @id @default(uuid())
  type String @db.VarChar(20)
  name String @db.VarChar(100)

  @@unique([type, name])
  @@map("categories")
}

model Result {
  id          String   @id @default(uuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  session     String   @default("")
  term        String
  marks       Json
  attendance  Json?
  comment     String?
  createdAt   DateTime @default(now())

  @@unique([studentId, term, session])
  @@index([studentId])
  @@index([session])
}

model Transaction {
  id                    String    @id @default(uuid()) @db.Uuid
  transactionDate       DateTime  @map("transaction_date")
  transactionType       String    @map("transaction_type") @db.VarChar(50)
  sourceAccount         String?   @map("source_account") @db.VarChar(100)
  destinationAccount    String?   @map("destination_account") @db.VarChar(100)
  amount                Decimal   @db.Decimal(12, 2)
  category              String?   @db.VarChar(100)
  description           String?   @db.Text
  studentId             String?   @map("student_id")
  student               Student?  @relation(fields: [studentId], references: [id], onDelete: SetNull)
  className             String?   @map("class_name") @db.VarChar(100)
  affectsIncomeLedger   Boolean   @default(false) @map("affects_income_ledger")
  affectsExpenseLedger  Boolean   @default(false) @map("affects_expense_ledger")
  createdBy             String?   @map("created_by") @db.VarChar(100)
  approvedBy            String?   @map("approved_by") @db.VarChar(100)
  referenceId           String?   @unique @map("reference_id") @db.VarChar(255)
  feeMonth              String?   @map("fee_month") @db.VarChar(20)
  fiscalYear            Int?      @map("fiscal_year")
  receiptSequence       Int?      @map("receipt_sequence")
  isCancelled           Boolean   @default(false) @map("is_cancelled")
  cancelledAt           DateTime? @map("cancelled_at")
  cancelledBy           String?   @map("cancelled_by") @db.VarChar(100)
  cancelReason          String?   @map("cancel_reason") @db.Text
  reversalOfId          String?   @map("reversal_of_id") @db.Uuid
  createdAt             DateTime  @default(now()) @map("created_at")

  paymentAllocations PaymentAllocation[]

  @@index([transactionDate])
  @@index([transactionType])
  @@index([studentId])
  @@index([className])
  @@index([category])
  @@index([studentId, category])
  @@index([className, category])
  @@index([transactionType, affectsIncomeLedger])
  @@index([reversalOfId])
  @@index([fiscalYear])
  @@map("transactions")
}

model ReceiptCounter {
  id           String @id @default(uuid()) @db.Uuid
  fiscalYear   Int    @map("fiscal_year")
  receiptType  String @map("receipt_type") @db.VarChar(20)
  nextSequence Int    @default(1) @map("next_sequence")

  @@unique([fiscalYear, receiptType])
  @@map("receipt_counters")
}

model FeeWaiver {
  id             String      @id @default(uuid())
  studentId      String      @map("student_id")
  feeScheduleId  String      @map("fee_schedule_id") @db.Uuid
  type           String      @db.VarChar(20) // CUSTOM_AMOUNT only
  value          Decimal     @db.Decimal(12, 2)
  reason         String?     @db.Text
  approvedBy     String?     @db.VarChar(100)
  active         Boolean     @default(true)
  startsAt       DateTime?   @map("starts_at")
  endsAt         DateTime?   @map("ends_at")
  createdAt      DateTime    @default(now()) @map("created_at")

  student        Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  feeSchedule    FeeSchedule @relation(fields: [feeScheduleId], references: [id], onDelete: Cascade)

  @@unique([studentId, feeScheduleId])
  @@index([studentId])
  @@index([feeScheduleId])
  @@map("fee_waivers")
}

model StudentFeeAssignment {
  id            String      @id @default(uuid())
  studentId     String      @map("student_id")
  feeScheduleId String      @map("fee_schedule_id") @db.Uuid
  active        Boolean     @default(true)
  startsAt      DateTime?   @map("starts_at")
  endsAt        DateTime?   @map("ends_at")
  note          String?     @db.Text
  createdAt     DateTime    @default(now()) @map("created_at")

  student       Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  feeSchedule   FeeSchedule @relation(fields: [feeScheduleId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([feeScheduleId])
  @@index([studentId, feeScheduleId])
  @@map("student_fee_assignments")
}

model OpeningBalance {
  id        String   @id @default(uuid())
  fiscalYear Int     @map("fiscal_year")
  account   String   @db.VarChar(100)
  amount    Decimal  @db.Decimal(12, 2) @default(0)
  updatedAt DateTime @updatedAt @map("updated_at")
  updatedBy String?  @map("updated_by") @db.VarChar(100)

  @@unique([fiscalYear, account])
  @@map("opening_balances")
}

model OpeningBalanceHistory {
  id         String   @id @default(uuid())
  fiscalYear Int      @map("fiscal_year")
  account    String   @db.VarChar(100)
  oldAmount  Decimal  @db.Decimal(12, 2) @default(0) @map("old_amount")
  newAmount  Decimal  @db.Decimal(12, 2) @default(0) @map("new_amount")
  changedBy  String?  @map("changed_by") @db.VarChar(100)
  changedAt  DateTime @default(now()) @map("changed_at")

  @@index([fiscalYear, account])
  @@map("opening_balance_history")
}

model PeriodClose {
  id        String   @id @default(uuid())
  fiscalYear Int     @unique @map("fiscal_year")
  closedAt  DateTime @default(now()) @map("closed_at")
  closedBy  String?  @map("closed_by") @db.VarChar(100)
  notes     String?  @db.Text

  @@map("period_closes")
}

model Reconciliation {
  id             String   @id @default(uuid())
  account        String   @db.VarChar(100)
  statementDate  DateTime @map("statement_date")
  closingBalance Decimal  @map("closing_balance") @db.Decimal(12, 2)
  systemBalance  Decimal  @default(0) @map("system_balance") @db.Decimal(12, 2)
  difference     Decimal  @default(0) @db.Decimal(12, 2)
  status         String   @default("pending") @db.VarChar(20)
  notes          String?  @db.Text
  createdAt      DateTime @default(now()) @map("created_at")
  createdBy      String?  @map("created_by") @db.VarChar(100)

  @@index([account])
  @@index([createdAt])
  @@map("reconciliations")
}
