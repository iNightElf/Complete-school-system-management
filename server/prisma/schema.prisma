generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model user {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  emailVerified Boolean  @default(false)
  image         String?
  role          String    @default("viewer") // "admin" | "viewer"
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  session       session[]
  account       account[]
}

model session {
  id           String    @id @default(uuid())
  expiresAt    DateTime
  token        String    @unique
  ipAddress    String?
  userAgent    String?
  userId       String
  user         user      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model account {
  id                    String    @id @default(uuid())
  accountId             String
  providerId            String
  userId                String
  user                  user      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([accountId, providerId])
}

model verification {
  id         String    @id @default(uuid())
  identifier String
  expiresAt  DateTime
  token      String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([identifier, token])
}

model Student {
  id          String           @id @default(uuid())
  class       String
  roll        String?
  name        String
  fatherName  String?
  motherName  String?
  contact     String?
  photo       Bytes?
  createdAt   DateTime         @default(now())
  results     Result[]
  transactions Transaction[]
  feeAssignments FeeAssignment[]

  @@index([class])
}

model Teacher {
  id          String   @id @default(uuid())
  designation String
  name        String
  email       String?
  contact     String?
  photo       Bytes?
  createdAt   DateTime @default(now())
}

model Staff {
  id          String   @id @default(uuid())
  role        String
  name        String
  email       String?
  contact     String?
  photo       Bytes?
  createdAt   DateTime @default(now())
}

model SchoolClass {
  id        String    @id @default(uuid())
  name      String    @unique
  order     Int       @default(0)
  subjects  Subject[]
  books     Book[]
}

model Subject {
  id          String      @id @default(cuid())
  name        String
  fullMarks   Int
  order       Int         @default(0)
  classId     String
  class       SchoolClass @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@unique([name, classId])
  @@index([classId])
}

model Book {
  id          String      @id @default(uuid())
  name        String
  publication String?
  mrp         Decimal     @db.Decimal(12, 2)
  discounted  Decimal     @db.Decimal(12, 2)
  sell        Decimal     @db.Decimal(12, 2)
  classId     String
  class       SchoolClass @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@index([classId])
}

model Result {
  id          String   @id @default(uuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  term        String
  marks       Json
  attendance  Json?
  comment     String?
  createdAt   DateTime @default(now())

  @@unique([studentId, term])
  @@index([studentId])
}

model Transaction {
  id                    String    @id @default(uuid()) @db.Uuid
  transactionDate       DateTime  @map("transaction_date")
  transactionType       String    @map("transaction_type") @db.VarChar(50)
  sourceAccount         String?   @map("source_account") @db.VarChar(100)
  destinationAccount    String?   @map("destination_account") @db.VarChar(100)
  amount                Decimal   @db.Decimal(12, 2)
  category              String?   @db.VarChar(100)
  description           String?   @db.Text
  studentId             String?   @map("student_id")
  student               Student?  @relation(fields: [studentId], references: [id], onDelete: SetNull)
  className             String?   @map("class_name") @db.VarChar(100)
  affectsIncomeLedger   Boolean   @default(false) @map("affects_income_ledger")
  affectsExpenseLedger  Boolean   @default(false) @map("affects_expense_ledger")
  createdBy             String?   @map("created_by") @db.VarChar(100)
  approvedBy            String?   @map("approved_by") @db.VarChar(100)
  referenceId           String?   @map("reference_id") @db.VarChar(255)
  createdAt             DateTime  @default(now()) @map("created_at")

  @@index([transactionDate])
  @@index([transactionType])
  @@index([studentId])
  @@index([className])
  @@index([category])
  @@index([studentId, category])
  @@index([className, category])
  @@index([transactionType, affectsIncomeLedger])
  @@map("transactions")
}

model FeeAssignment {
  id          String   @id @default(uuid())
  studentId   String   @map("student_id")
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  feeType     String   @map("fee_type") @db.VarChar(50)
  amount      Decimal  @db.Decimal(12, 2) @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([studentId, feeType])
  @@index([active, studentId])
  @@map("fee_assignments")
}
